{
  "version": 2,
  "functions": {
    "api/*.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/x/BitWrap/(.*)",
      "dest": "/api/convert/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}